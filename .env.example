# Прокси /api в next.config (как в Vite) и база для клиентских запросов
NEXT_PUBLIC_MEDIA_ORIGIN=http://pp.ppdlme.xyz/

# Серверный fetch для SEO (generateMetadata, robots.txt) — абсолютный URL API
API_ORIGIN=http://pp.ppdlme.xyz/

# Локаль для `<link>` из base.tags в layout (по умолчанию en)
# NEXT_PUBLIC_DEFAULT_LOCALE=en

# Необязательно: заменить все строки Sitemap: в robots.txt на один URL (абсолютный)
# ROBOTS_SITEMAP_URL=https://example.com/sitemap_index.xml
